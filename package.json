{
  "name": "gametok-backend",
  "version": "1.0.1",
  "description": "GameTok API backend",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed-bots": "node seed-bots.js",
    "bots:bootstrap": "node scripts/bots-bootstrap.mjs --count 2000 --games 80 --actions 2500",
    "bots:status": "node scripts/bots-bootstrap.mjs --status",
    "bots:tick": "node scripts/bots-bootstrap.mjs --tick 1000",
    "bots:dream": "node scripts/bots-bootstrap.mjs --dream 1",
    "bots:dream:batch": "node scripts/bots-bootstrap.mjs --dream 5 --dream-concurrency 1",
    "bots:regenerate": "node scripts/bots-bootstrap.mjs --regenerate 500",
    "covers:backfill": "node scripts/cover-backfill.mjs --limit 50",
    "covers:backfill:all": "node scripts/cover-backfill.mjs --limit 500 --all",
    "covers:regenerate": "node regenerate-all-thumbnails.js",
    "covers:regenerate:test": "node regenerate-all-thumbnails.js --limit=5 --dry-run",
    "check:bots": "node --check src/bot-engine.js && node --check src/index.js && node --check scripts/bots-bootstrap.mjs && node --check src/cover-art.js && node --check src/cover-art-router.js && node --check scripts/cover-backfill.mjs",
    "check:ai-engine": "node --check src/ai-engine/routes.js && node --check src/ai-engine/forge-autoscale.js && node --check src/ai-engine/real-opengame-runner.js && node --check src/ai-engine/sandbox.js && node --check src/ai-engine/sprite-generator.js && node --check src/ai-engine/nvidia-key-pool.js && node --check src/ai-engine/maker-foundation-stub-validator.js && node --check src/ai-engine/maker-agent-response.js && node --check src/ai-engine/maker-agent-patches.js && node --check src/ai-engine/maker-project-compile-gate.js && node --check src/ai-engine/maker-agent-stream.js && node --check src/ai-engine/stream-diagnostics.js && node --check src/ai-engine/provider-retry-policy.js && node scripts/check-maker-agent-response.mjs && node scripts/check-maker-agent-patches.mjs && node scripts/check-sandbox-probe.mjs && node scripts/check-main-ts-dedupe.mjs && node scripts/check-sprite-quality.mjs && node scripts/check-animation-frame-acceptance.mjs && node scripts/check-forge-autoscale.mjs && node scripts/check-foundation-stub.mjs && node --check src/db.js",
    "check:foundation-stub": "node scripts/check-foundation-stub.mjs",
    "check:foundation-stub:compile": "node scripts/check-foundation-stub.mjs --compile",
    "benchmark:sekai": "node scripts/gametok-maker-benchmark.js",
    "maker": "node scripts/gametok-maker.js",
    "maker:env": "node scripts/gametok-maker.js env",
    "maker:inspect": "node scripts/gametok-maker.js inspect",
    "maker:worker": "node scripts/gametok-maker-worker.js",
    "forge:autoscale": "node scripts/forge-autoscaler.mjs",
    "forge:autoscale:report": "node scripts/forge-autoscaler.mjs --report",
    "forge:autoscale:dry-run": "node scripts/forge-autoscaler.mjs --dry-run",
    "opengame:worker": "node scripts/opengame-worker.js",
    "catalog:kenney": "node scripts/build_kenney_inventory.mjs",
    "catalog:kenney:full": "node scripts/build_kenney_catalog.mjs",
    "manifest:kenney-wave1": "node scripts/build_kenney_wave1_manifest.mjs",
    "stage:kenney-wave1": "node scripts/stage_kenney_wave1_assets.mjs",
    "catalog:kenney-wave1": "node scripts/build_kenney_wave1_catalog.mjs",
    "catalog:kenney-wave1:intelligence": "node scripts/build_kenney_wave1_intelligence.mjs",
    "manifest:phaser": "node scripts/build_phaser_asset_manifest.mjs",
    "assets:kenney-wave1:upload": "node scripts/upload_kenney_wave1_assets_to_r2.mjs",
    "assets:kenney:upload": "node scripts/upload_kenney_assets_to_r2.mjs",
    "assets:phaser:upload": "node scripts/upload_phaser_assets_to_r2.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1039.0",
    "@google/generative-ai": "^0.24.1",
    "@imgly/background-removal-node": "^1.4.5",
    "autoprefixer": "^10.5.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "duckduckgo-images-api": "^1.0.5",
    "expo-server-sdk": "^3.11.0",
    "express": "^4.18.2",
    "images-scraper": "^7.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "ora": "^9.4.0",
    "pg": "^8.20.0",
    "phaser": "^3.90.0",
    "phaser3-rex-plugins": "^1.80.20",
    "postcss": "^8.5.15",
    "puppeteer": "^24.40.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tailwindcss": "^3.4.19",
    "tiktoken": "^1.0.22",
    "typescript": "^6.0.3",
    "uuid": "^9.0.0",
    "vite": "^8.0.13",
    "vite-plugin-singlefile": "^2.3.3",
    "youtube-dl-exec": "^3.1.4"
  },
  "type": "module"
}
